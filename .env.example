# Catalog Scanner — environment
#
# This scanner writes into the SAME Supabase project that ingredients.help
# reads. Point these at that project (not a new one) or the composition never
# reaches the consumer app.

# Supabase — the shared catalog database.
# URL is the public project URL; the SERVICE ROLE key bypasses RLS and is used
# ONLY server-side (never shipped to the browser). Keep it secret.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — the same key ingredients.help uses for reports. Used server-side
# by /api/process to read ingredient/brand photos with Claude vision.
ANTHROPIC_API_KEY=

# Model for label transcription. Haiku is plenty and cheap (~$0.005/label).
EXTRACT_MODEL=claude-haiku-4-5

# Admin gate — a shared secret. Everything (the capture page and the process
# endpoint) is gated behind this, sent as the x-admin-token header. Reuses the
# same pattern as ingredients.help's /admin/* routes.
ADMIN_TOKEN=
